<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Themes.MainPage">

    <ScrollView>
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Spacing="10">

            <Button Text="Светлая" Clicked="OnLightClicked"/>
            <Button Text="Темная" Clicked="OnDarkClicked"/>
            <Button Text="Системная" Clicked="OnSystemClicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
